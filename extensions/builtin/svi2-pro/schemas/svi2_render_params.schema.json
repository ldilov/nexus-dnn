{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-dnn.local/extensions/nexus-video-svi2-pro/schemas/svi2_render_params.schema.json",
  "title": "Svi2RenderParams",
  "type": "object",
  "additionalProperties": false,
  "required": ["prompts"],
  "allOf": [
    {
      "if": {
        "properties": { "mode": { "const": "text_to_video" } },
        "required": ["mode"]
      },
      "then": true,
      "else": {
        "required": ["ref_image_path"]
      }
    }
  ],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["image_to_video", "text_to_video"],
      "default": "image_to_video"
    },
    "seed": {
      "type": "integer",
      "minimum": 0
    },
    "seed_strength": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "ref_image_path": {
      "type": "string",
      "minLength": 1
    },
    "prompts": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "last_image_path": {
      "type": ["string", "null"]
    },
    "requires_last_image": {
      "type": "boolean",
      "default": false
    },
    "num_clips": {
      "type": "integer",
      "minimum": 1
    },
    "height": {
      "type": "integer",
      "minimum": 1,
      "default": 832
    },
    "width": {
      "type": "integer",
      "minimum": 1,
      "default": 480
    },
    "fps": {
      "type": "integer",
      "minimum": 1,
      "default": 15
    },
    "interpolate_fps": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "upscale_factor": {
      "type": "integer",
      "enum": [0, 2, 3, 4],
      "default": 0
    },
    "upscale_quality": {
      "type": "string",
      "enum": [
        "LOW",
        "MEDIUM",
        "HIGH",
        "ULTRA",
        "HIGHBITRATE_LOW",
        "HIGHBITRATE_MEDIUM",
        "HIGHBITRATE_HIGH",
        "HIGHBITRATE_ULTRA"
      ],
      "default": "HIGH"
    },
    "interpolate_method": {
      "type": "string",
      "enum": ["rife", "rife_torch", "rife_ncnn", "ffmpeg"],
      "default": "rife"
    },
    "rife_bin": {
      "type": ["string", "null"]
    },
    "rife_model": {
      "type": ["string", "null"]
    },
    "rife_weights": {
      "type": ["string", "null"]
    },
    "frames_per_clip": {
      "type": "integer",
      "minimum": 1,
      "default": 81
    },
    "num_inference_steps": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 50
    },
    "sigma_shift": {
      "type": "number",
      "minimum": 0,
      "maximum": 20,
      "default": 5.0
    },
    "switch_boundary": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "default": 0.9
    },
    "stitch_mode": {
      "type": "string",
      "enum": ["trim", "crossfade"],
      "default": "crossfade"
    },
    "ref_pad_num": {
      "type": "integer",
      "minimum": -1,
      "maximum": 16,
      "default": 0
    },
    "ref_pad_free_clips": {
      "type": "integer",
      "minimum": 0,
      "default": 2
    },
    "adain_factor": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "default": 0.0
    },
    "motion_scale_schedule": {
      "type": ["array", "null"],
      "items": { "type": "number" }
    },
    "cfg_scale": {
      "type": "number",
      "minimum": 1,
      "maximum": 12,
      "default": 5.0
    },
    "num_overlap_frame": {
      "type": "integer",
      "minimum": 1,
      "maximum": 8,
      "default": 4
    },
    "num_motion_latent": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5,
      "default": 1
    },
    "image_cond_noise_scale": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "default": 0.0
    },
    "image_cond_noise_schedule": {
      "type": ["array", "null"],
      "items": { "type": "number" }
    },
    "image_cond_noise_bg_protect": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "default": 0.0
    },
    "pixel_re_encode": {
      "type": "boolean",
      "default": true
    },
    "num_motion_frame": {
      "type": "integer",
      "minimum": 1,
      "maximum": 16,
      "default": 4
    },
    "blocks_to_swap": {
      "type": "integer",
      "minimum": 0,
      "maximum": 40,
      "default": 20
    },
    "seed_multiplier": {
      "type": "integer",
      "default": 42
    },
    "output_path": {
      "type": "string"
    },
    "models_dir": {
      "type": "string"
    },
    "lora_path": {
      "type": "string"
    },
    "dit_high_path": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "dit_low_path": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "device": {
      "type": ["string", "null"]
    },
    "distill_lora_high": {
      "type": ["string", "null"]
    },
    "distill_lora_low": {
      "type": ["string", "null"]
    },
    "fixed_sigmas": {
      "type": ["array", "null"],
      "items": { "type": "number" }
    },
    "attention": {
      "type": ["string", "null"],
      "default": null
    },
    "teacache_multiplier": {
      "type": ["number", "null"],
      "default": 1.0
    },
    "teacache_thresh": {
      "type": ["number", "null"]
    }
  }
}
