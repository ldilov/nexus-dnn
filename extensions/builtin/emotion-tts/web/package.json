{
  "name": "@nexus/emotion-tts-web",
  "version": "0.1.0",
  "private": true,
  "description": "Frontend bundle for the EmotionTTS Nexus extension (spec 031). Mounts under the host's generic /extensions/:layoutId route.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "biome lint src",
    "lint:css": "stylelint \"src/**/*.css.ts\"",
    "format": "biome format --write src"
  },
  "dependencies": {
    "@vanilla-extract/css": "^1.17.0",
    "motion": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.14.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.48.0",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vanilla-extract/vite-plugin": "^4.0.20",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "stylelint": "^16.12.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
