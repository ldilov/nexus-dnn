{
  "name": "nexus-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && pnpm scan:cdn",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test --project=visual",
    "test:smoke": "playwright test --project=smoke",
    "test:regression": "pnpm test:smoke && pnpm test:visual",
    "scan:theme": "node scripts/scan-theme-leaks.mjs",
    "scan:terminology": "node scripts/scan-terminology.mjs",
    "scan:cdn": "node scripts/scan-remote-cdns.mjs",
    "scan:noop": "node scripts/scan-noop-handlers.mjs",
    "scan:constitution": "node scripts/scan-constitution.mjs",
    "scan:bundle-size": "node scripts/bundle-size-check.mjs",
    "scan:all": "pnpm scan:theme && pnpm scan:terminology && pnpm scan:noop && pnpm scan:constitution"
  },
  "dependencies": {
    "@dagrejs/dagre": "^1.1.0",
    "@tanstack/react-virtual": "^3.10.0",
    "@vanilla-extract/css": "^1.17.0",
    "@vanilla-extract/recipes": "^0.5.0",
    "@vanilla-extract/sprinkles": "^1.6.0",
    "@xyflow/react": "^12.0.0",
    "motion": "^12.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.14.1",
    "react-router-dom": "^7.14.1",
    "sonner": "^2.0.7",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/types": "^8.0.0",
    "@typescript-eslint/typescript-estree": "^8.0.0",
    "@vanilla-extract/vite-plugin": "^5.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
