{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "nexus-dnn",
  "version": "0.1.0",
  "identifier": "com.nexus-dnn.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter web dev",
    "beforeBuildCommand": "pnpm --filter web build"
  },
  "app": {
    "windows": [
      {
        "title": "nexus-dnn",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false,
        "titleBarStyle": "Overlay",
        "transparent": true,
        "hiddenTitle": true,
        "fullscreen": false,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico", "icons/icon.icns"],
    "category": "DeveloperTool",
    "shortDescription": "Local AI cockpit",
    "longDescription": "nexus-dnn — desktop console for local LLM runtimes, GGUF model loading, and ops telemetry."
  }
}
