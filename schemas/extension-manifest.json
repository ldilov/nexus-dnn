{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-dnn.dev/schemas/extension-manifest.json",
  "type": "object",
  "required": ["spec_version", "extension", "compatibility", "runtime"],
  "properties": {
    "spec_version": {
      "type": "string",
      "enum": ["0.1", "0.2"]
    },
    "extension": {
      "type": "object",
      "required": ["id", "version"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9-]+(?:\\.[a-zA-Z0-9-]+)+$"
        },
        "version": {
          "type": "string",
          "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-((?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*)(?:\\.(?:0|[1-9]\\d*|\\d*[a-zA-Z-][0-9a-zA-Z-]*))*))?(?:\\+([0-9a-zA-Z-]+(?:\\.[0-9a-zA-Z-]+)*))?$"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "publisher": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "compatibility": {
      "type": "object",
      "required": ["host_api", "protocol"],
      "properties": {
        "host_api": {
          "type": "string"
        },
        "protocol": {
          "type": "string"
        },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "runtime": {
      "type": "object",
      "required": ["family", "entrypoint"],
      "properties": {
        "family": {
          "type": "string",
          "enum": ["python", "native", "builtin", "external_service"]
        },
        "entrypoint": {
          "type": "string"
        },
        "environment": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "gpu.compute",
          "filesystem.read",
          "filesystem.write",
          "network.loopback",
          "network.remote",
          "process.spawn",
          "model.registry.read",
          "workspace.read",
          "workspace.write",
          "storage.schema_contribute",
          "huggingface.search",
          "huggingface.install"
        ]
      }
    },
    "runtime_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["family"],
        "properties": {
          "family": { "type": "string" },
          "version": { "type": "string" },
          "acceleration": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "model_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["family", "version"],
        "properties": {
          "family": { "type": "string" },
          "version": { "type": "string" },
          "revision": { "type": ["string", "null"] },
          "allow_unpinned": { "type": "boolean" },
          "min_params": { "type": ["string", "integer", "null"] },
          "quantization": { "type": ["string", "null"] },
          "variant": { "type": ["string", "null"] },
          "required": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "dependencies": {
      "type": "object",
      "required": ["steps"],
      "properties": {
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "type"],
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string" },
              "requires": {
                "type": "array",
                "items": { "type": "string" }
              },
              "spec": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "backend_runtimes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["runtime_id", "display_name", "family", "transport", "worker_entrypoint", "version_manifest"],
        "properties": {
          "runtime_id": { "type": "string" },
          "display_name": { "type": "string" },
          "family": { "type": "string" },
          "transport": { "type": "string" },
          "worker_entrypoint": { "type": "string" },
          "version_manifest": { "type": "string" },
          "capability_tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "supported_roles": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "operators": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file"],
        "properties": {
          "file": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "recipes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file"],
        "properties": {
          "file": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "storage": {
      "$ref": "storage-contribution.schema.json"
    },
    "ui": {
      "type": "object",
      "properties": {
        "layouts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file"],
            "properties": {
              "file": { "type": "string" },
              "placement": { "type": "string", "enum": ["main", "sidebar", "inspector"] },
              "default": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        },
        "contributions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["file"],
            "properties": {
              "file": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "assets": {
          "type": "object",
          "required": ["root"],
          "properties": {
            "root": { "type": "string" }
          },
          "additionalProperties": false
        },
        "custom_elements": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["tag", "module"],
            "properties": {
              "tag": { "type": "string", "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)+$" },
              "module": { "type": "string" },
              "entry": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}