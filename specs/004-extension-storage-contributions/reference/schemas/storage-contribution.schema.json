{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus.local/schemas/storage-contribution.schema.json",
  "title": "Nexus Storage Contribution",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "spec_version",
    "engine",
    "namespace",
    "migrations",
    "sql_profile"
  ],
  "properties": {
    "spec_version": {
      "type": "string",
      "const": "0.1"
    },
    "engine": {
      "type": "string",
      "const": "sqlite"
    },
    "namespace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["alias", "prefix_mode"],
      "properties": {
        "alias": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]{2,48}$"
        },
        "prefix_mode": {
          "type": "string",
          "const": "host_derived"
        }
      }
    },
    "migrations": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "files"],
      "properties": {
        "strategy": {
          "type": "string",
          "const": "sql_file_list"
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "path"],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^[0-9]{3}_[a-z0-9_]{2,64}$"
              },
              "path": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "sql_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["profile"],
      "properties": {
        "profile": {
          "type": "string",
          "const": "nexus_sqlite_v1"
        }
      }
    },
    "uninstall": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "policy": {
          "type": "string",
          "enum": [
            "retain",
            "drop_namespace_objects",
            "archive_then_drop"
          ]
        }
      }
    },
    "runtime_access": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["host_api_only"]
        }
      }
    }
  }
}
