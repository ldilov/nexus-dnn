### GET /api/v1/host-models/{install_id}/dependents
### Returns the distinct extensions that currently lease, or declare a dep on,
### the given host-model install. Powers the "Shared by N extension(s)" chip.

GET {{host}}/api/v1/host-models/hmi_01HWABC.../dependents HTTP/1.1
Accept: application/json

### 200 OK — happy path
###
### {
###   "meta": {...},
###   "data": {
###     "count": 2,
###     "extensions": [
###       { "extension_id": "local-llm", "display_name": "Local LLM Chat", "kind": "lease" },
###       { "extension_id": "code-assist", "display_name": "Code Assistant", "kind": "declared_dep" }
###     ]
###   }
### }

### 404 NOT_FOUND — unknown install id
###
### { "meta": {...}, "error": { "code": "not_found", "message": "host model install hmi_... not found" } }

### 200 OK — zero dependents (freshly installed, no extension has leased yet)
###
### {
###   "meta": {...},
###   "data": { "count": 0, "extensions": [] }
### }
