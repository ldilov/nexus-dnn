{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-dnn.local/schemas/workflow.v2.schema.json",
  "title": "WorkflowV2",
  "type": "object",
  "required": ["specVersion", "workflow"],
  "properties": {
    "specVersion": { "const": "0.2" },
    "workflow": {
      "type": "object",
      "required": ["id", "version", "title", "inputs", "outputs", "stages", "nodes"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_][a-z0-9_-]*$" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?$" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "labels": { "type": "array", "items": { "type": "string" } },
        "source": {
          "type": "object",
          "properties": {
            "kind": { "enum": ["extension_template", "user_created", "migrated_from_v1", "imported"] },
            "extensionId": { "type": "string" },
            "templateRef": { "type": "string" }
          },
          "required": ["kind"]
        },
        "mappingState": { "enum": ["fully_mapped", "partially_mapped", "custom", "unmappable"] },
        "inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "cardinality": { "enum": ["one", "optional", "many"], "default": "one" },
              "description": { "type": "string" }
            }
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "from"],
            "properties": {
              "name": { "type": "string" },
              "from": { "type": "string", "pattern": "^[a-z0-9_][a-z0-9_-]*:[a-z0-9_][a-z0-9_-]*$" }
            }
          }
        },
        "stages": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "description": { "type": "string" },
              "order": { "type": "integer" }
            }
          }
        },
        "subgraphs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "label", "containedNodeIds"],
            "properties": {
              "id": { "type": "string" },
              "label": { "type": "string" },
              "containedNodeIds": { "type": "array", "items": { "type": "string" } },
              "exposedInputs": { "type": "array" },
              "exposedOutputs": { "type": "array" },
              "ui": { "type": "object" }
            }
          }
        },
        "nodes": {
          "type": "array",
          "items": { "$ref": "#/$defs/NodeInstance" }
        },
        "bindings": {
          "type": "array",
          "items": { "$ref": "#/$defs/Binding" }
        },
        "annotations": { "type": "object" },
        "uiState": { "type": "object" }
      }
    }
  },
  "$defs": {
    "NodeInstance": {
      "type": "object",
      "required": ["id", "operatorRef"],
      "properties": {
        "id": { "type": "string" },
        "operatorRef": {
          "type": "object",
          "required": ["operatorId", "version"],
          "properties": {
            "operatorId": { "type": "string" },
            "version": { "type": "string" }
          }
        },
        "extensionId": { "type": "string" },
        "displayName": { "type": "string" },
        "nodeClass": {
          "type": "array",
          "items": { "type": "string" }
        },
        "stageId": { "type": "string" },
        "subgraphId": { "type": "string" },
        "availabilityState": {
          "enum": ["active", "missing_operator", "incompatible_version", "missing_runtime_adapter",
                    "disabled_by_extension", "missing_dependency", "invalid_config", "orphaned"]
        },
        "mappingState": {
          "enum": ["fully_mapped", "partially_mapped", "customized", "unmapped"]
        },
        "config": { "type": "object" },
        "runtimeBindings": { "type": "object" },
        "modelParameters": { "type": "object" },
        "requestParameters": { "type": "object" },
        "inputs": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["source"],
            "properties": {
              "source": { "$ref": "#/$defs/NodeInputSource" }
            }
          }
        },
        "resources": { "type": "object" },
        "ui": { "type": "object" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      }
    },
    "NodeInputSource": {
      "oneOf": [
        { "type": "object", "required": ["kind", "ref"],
          "properties": {
            "kind": { "const": "workflow_input" },
            "ref": { "type": "string", "pattern": "^input:[a-z0-9_][a-z0-9_-]*$" }
          } },
        { "type": "object", "required": ["kind", "ref"],
          "properties": {
            "kind": { "const": "node_output" },
            "ref": { "type": "string", "pattern": "^[a-z0-9_][a-z0-9_-]*:[a-z0-9_][a-z0-9_-]*$" }
          } },
        { "type": "object", "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "literal" },
            "value": {}
          } },
        { "type": "object", "required": ["kind", "fieldId"],
          "properties": {
            "kind": { "const": "recipe_binding" },
            "fieldId": { "type": "string" }
          } },
        { "type": "object", "required": ["kind", "runId", "artifactId"],
          "properties": {
            "kind": { "const": "previous_run_artifact" },
            "runId": { "type": "string" },
            "artifactId": { "type": "string" }
          } },
        { "type": "object", "required": ["kind", "key"],
          "properties": {
            "kind": { "const": "runtime_context" },
            "key": { "type": "string" }
          } }
      ]
    },
    "Binding": {
      "type": "object",
      "required": ["bindingId", "source", "target"],
      "properties": {
        "bindingId": { "type": "string" },
        "source": {
          "type": "object",
          "required": ["kind", "ref", "port"],
          "properties": {
            "kind": { "enum": ["workflow_input", "node_output"] },
            "ref": { "type": "string" },
            "port": { "type": "string" },
            "transport": { "enum": ["literal_value", "artifact_ref", "runtime_handle", "deployment_ref", "stream_ref"] },
            "conversionRef": { "type": "string" }
          }
        },
        "target": {
          "type": "object",
          "required": ["nodeId", "port"],
          "properties": {
            "nodeId": { "type": "string" },
            "port": { "type": "string" }
          }
        },
        "declaredType": { "type": "string" },
        "resolvedType": { "type": "string" },
        "validationState": {
          "enum": ["valid", "type_mismatch", "missing_source", "missing_target",
                   "operator_unavailable", "ambiguous", "stale_due_to_version_change"]
        },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  }
}
