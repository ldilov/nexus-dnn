{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-dnn.local/schemas/operator.v2.schema.json",
  "title": "OperatorDefinitionV2",
  "type": "object",
  "required": ["specVersion", "operator", "execution", "inputs", "outputs"],
  "properties": {
    "specVersion": { "const": "0.2" },
    "operator": {
      "type": "object",
      "required": ["id", "version", "displayName", "category"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9_][a-z0-9_.-]*$" },
        "version": { "type": "string" },
        "displayName": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "nodeClass": {
          "type": "array",
          "items": {
            "enum": ["pure_transform", "source", "sink", "model_load",
                      "inference", "utility", "aggregation", "inspection", "deployment"]
          },
          "minItems": 1
        }
      }
    },
    "execution": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["job", "streaming", "service"] },
        "cacheable": { "type": "boolean", "default": false },
        "resumable": { "type": "boolean", "default": false },
        "determinism": { "enum": ["deterministic", "bounded", "nondeterministic"], "default": "bounded" }
      }
    },
    "inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/PortSpec" }
    },
    "outputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/PortSpec" }
    },
    "configSchema": { "type": "object" },
    "parameterGroups": {
      "type": "object",
      "properties": {
        "config": { "$ref": "#/$defs/ParameterGroup" },
        "runtime": { "$ref": "#/$defs/ParameterGroup" },
        "model": { "$ref": "#/$defs/ParameterGroup" },
        "generation": { "$ref": "#/$defs/ParameterGroup" },
        "resources": { "$ref": "#/$defs/ParameterGroup" },
        "output": { "$ref": "#/$defs/ParameterGroup" },
        "debug": { "$ref": "#/$defs/ParameterGroup" }
      },
      "additionalProperties": false
    },
    "capabilities": {
      "type": "array",
      "items": {
        "enum": ["filesystem.read", "filesystem.write", "network.loopback", "network.remote",
                  "process.spawn", "gpu.compute", "workspace.read", "workspace.write", "model.registry.read"]
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "gpu": { "type": "boolean" },
        "minVramMb": { "type": "integer", "minimum": 0 },
        "cpuCores": { "type": "integer", "minimum": 0 },
        "ramMb": { "type": "integer", "minimum": 0 },
        "warmWorker": { "type": "boolean" },
        "batchSupport": { "type": "boolean" },
        "streamingSupport": { "type": "boolean" },
        "localOnly": { "type": "boolean" },
        "networkRequired": { "type": "boolean" }
      }
    },
    "ui": { "$ref": "./ui-metadata.v2.schema.json" }
  },
  "$defs": {
    "PortSpec": {
      "type": "object",
      "required": ["name", "type"],
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string" },
        "direction": { "enum": ["input", "output"] },
        "cardinality": { "enum": ["one", "optional", "many"], "default": "one" },
        "required": { "type": "boolean", "default": false },
        "default": {},
        "description": { "type": "string" },
        "transport": { "enum": ["literal_value", "artifact_ref", "runtime_handle", "deployment_ref", "stream_ref"], "default": "artifact_ref" },
        "bindingPolicy": { "type": "object" },
        "uiHints": { "type": "object" }
      }
    },
    "ParameterGroup": {
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/ParameterField" }
        }
      }
    },
    "ParameterField": {
      "type": "object",
      "required": ["name", "scope", "storage", "visibility"],
      "properties": {
        "name": { "type": "string" },
        "label": { "type": "string" },
        "description": { "type": "string" },
        "scope": { "enum": ["runtime", "model_load", "request", "structural", "ui_only"] },
        "storage": { "enum": ["workspace_default", "extension_default", "recipe_default", "workflow_value", "node_override", "session_override"] },
        "visibility": { "enum": ["hidden", "advanced", "standard", "recipe_exposed", "graph_only", "debug_only"] },
        "type": { "type": "string" },
        "default": {},
        "includeInCacheKey": { "type": "boolean", "default": false }
      }
    }
  }
}
