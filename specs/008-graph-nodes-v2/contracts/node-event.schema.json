{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-dnn.local/schemas/node-event.schema.json",
  "title": "NodeEvent",
  "oneOf": [
    { "$ref": "#/$defs/GraphMutationApplied" },
    { "$ref": "#/$defs/ValidationCompleted" },
    { "$ref": "#/$defs/RecipeMappingChanged" },
    { "$ref": "#/$defs/NodeAttemptStarted" },
    { "$ref": "#/$defs/NodeAttemptProgressed" },
    { "$ref": "#/$defs/NodeAttemptCompleted" },
    { "$ref": "#/$defs/NodeAttemptFailed" },
    { "$ref": "#/$defs/CacheDecisionMade" },
    { "$ref": "#/$defs/CapabilitySurfaceChanged" }
  ],
  "$defs": {
    "Base": {
      "type": "object",
      "required": ["type", "timestamp"],
      "properties": {
        "type": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "workflowId": { "type": "string" },
        "workflowVersionId": { "type": "string" },
        "runId": { "type": "string" },
        "attemptId": { "type": "string" }
      }
    },
    "GraphMutationApplied": {
      "allOf": [{ "$ref": "#/$defs/Base" }, {
        "properties": { "type": { "const": "v2.graph_mutation_applied" },
          "command": { "$ref": "./graph-mutation-commands.schema.json" } }
      }]
    },
    "ValidationCompleted": {
      "allOf": [{ "$ref": "#/$defs/Base" }, {
        "properties": { "type": { "const": "v2.validation_completed" },
          "summary": { "type": "object", "properties": {
            "errors": { "type": "integer" }, "warnings": { "type": "integer" }, "info": { "type": "integer" }
          } } }
      }]
    },
    "RecipeMappingChanged": {
      "allOf": [{ "$ref": "#/$defs/Base" }, {
        "properties": { "type": { "const": "v2.recipe_mapping_changed" },
          "recipeId": { "type": "string" }, "mappingState": { "type": "string" } }
      }]
    },
    "NodeAttemptStarted": {
      "allOf": [{ "$ref": "#/$defs/Base" }, {
        "properties": { "type": { "const": "v2.node_attempt_started" }, "nodeId": { "type": "string" },
          "attemptIndex": { "type": "integer" } }
      }]
    },
    "NodeAttemptProgressed": {
      "allOf": [{ "$ref": "#/$defs/Base" }, {
        "properties": { "type": { "const": "v2.node_attempt_progressed" }, "nodeId": { "type": "string" },
          "progress": { "type": "number" }, "phase": { "type": "string" }, "message": { "type": "string" } }
      }]
    },
    "NodeAttemptCompleted": {
      "allOf": [{ "$ref": "#/$defs/Base" }, {
        "properties": { "type": { "const": "v2.node_attempt_completed" }, "nodeId": { "type": "string" },
          "durationMs": { "type": "integer" }, "outputs": { "type": "object" } }
      }]
    },
    "NodeAttemptFailed": {
      "allOf": [{ "$ref": "#/$defs/Base" }, {
        "properties": { "type": { "const": "v2.node_attempt_failed" }, "nodeId": { "type": "string" },
          "failure": {
            "type": "object",
            "required": ["category", "code", "message", "retryable"],
            "properties": {
              "category": { "enum": ["validation_error", "type_mismatch", "runtime_missing",
                  "dependency_missing", "model_unavailable", "out_of_memory",
                  "execution_cancelled", "worker_crash", "internal_error", "output_registration_failed"] },
              "code": { "type": "string" }, "message": { "type": "string" }, "retryable": { "type": "boolean" },
              "details": {}
            }
          } }
      }]
    },
    "CacheDecisionMade": {
      "allOf": [{ "$ref": "#/$defs/Base" }, {
        "properties": { "type": { "const": "v2.cache_decision_made" }, "nodeId": { "type": "string" },
          "decision": { "enum": ["hit", "miss", "skip"] }, "reason": { "type": "string" },
          "cacheKey": { "type": "string" } }
      }]
    },
    "CapabilitySurfaceChanged": {
      "allOf": [{ "$ref": "#/$defs/Base" }, {
        "properties": { "type": { "const": "v2.capability_surface_changed" },
          "capabilities": { "type": "array", "items": { "type": "string" } } }
      }]
    }
  }
}
