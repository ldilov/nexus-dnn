{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-dnn/schemas/llm-backend-runtime-settings.json",
  "title": "LLM backend runtime settings (persistent defaults)",
  "type": "object",
  "required": [
    "backend",
    "threads",
    "threads_batch",
    "default_context",
    "parallel_requests",
    "bind_address",
    "port_mode",
    "extra_args"
  ],
  "additionalProperties": false,
  "properties": {
    "runtime_settings_id": { "type": "string", "pattern": "^rts_[0-9A-HJKMNP-TV-Z]{26}$" },
    "backend": { "type": "string", "enum": ["llama.cpp", "tensorrt_llm"] },
    "install_ref": {
      "type": ["string", "null"],
      "pattern": "^rtinst_[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "threads": { "type": "integer", "minimum": 1, "maximum": 1024 },
    "threads_batch": { "type": "integer", "minimum": 1, "maximum": 1024 },
    "default_context": { "type": "integer", "minimum": 128, "maximum": 1048576 },
    "parallel_requests": { "type": "integer", "minimum": 1, "maximum": 64 },
    "bind_address": { "type": "string", "minLength": 1 },
    "port_mode": { "type": "string", "enum": ["auto", "fixed"] },
    "fixed_port": { "type": ["integer", "null"], "minimum": 1, "maximum": 65535 },
    "extra_args": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "port_mode": { "const": "fixed" } }, "required": ["port_mode"] },
      "then": { "required": ["fixed_port"], "properties": { "fixed_port": { "type": "integer" } } }
    }
  ]
}
