{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-dnn/schemas/llm-backend-version-manifest.json",
  "title": "LLM backend version manifest",
  "type": "object",
  "required": ["backend", "releases"],
  "additionalProperties": false,
  "properties": {
    "backend": {
      "type": "string",
      "enum": ["llama.cpp", "tensorrt_llm"]
    },
    "default_release_id": { "type": "string" },
    "releases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["release_id", "assets"],
        "additionalProperties": false,
        "properties": {
          "release_id": { "type": "string", "pattern": "^[A-Za-z0-9._-]+$" },
          "release_notes_url": { "type": "string", "format": "uri" },
          "assets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["platform", "accelerator_profile", "url"],
              "additionalProperties": false,
              "properties": {
                "platform": {
                  "type": "string",
                  "enum": ["windows-x64", "linux-x64", "linux-arm64"]
                },
                "accelerator_profile": {
                  "type": "string",
                  "enum": ["cpu", "cuda12", "cuda13"]
                },
                "url": { "type": "string", "format": "uri" },
                "archive_kind": {
                  "type": "string",
                  "enum": ["zip", "tar.gz"]
                },
                "checksum_sha256": {
                  "type": "string",
                  "pattern": "^[A-Fa-f0-9]{64}$"
                },
                "size_bytes": { "type": "integer", "minimum": 1 },
                "binary_relpath": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
