# Embedded-Python distribution config (spec 032, T059a).
#
# Set these env vars before starting nexus-dnn to pin the portable
# CPython distribution used by every `family: python` backend runtime.
# Without a pinned asset, python-family installs fail at the
# `bootstrap_runtime` phase with `PythonBootstrapFailed`.
#
# Recommended source: https://github.com/astral-sh/python-build-standalone
#
# Pick the `install_only` tarball matching the host's target triple
# (e.g. `cpython-3.11.13+YYYYMMDD-x86_64-pc-windows-msvc-install_only.tar.gz`),
# download it once, compute sha256, then paste the values below.
#
# Example values (YOU MUST replace with a pin verified against the
# release page's published checksums):

NEXUS_EMBEDDED_PYTHON_URL=https://github.com/astral-sh/python-build-standalone/releases/download/YYYYMMDD/cpython-3.11.13+YYYYMMDD-x86_64-pc-windows-msvc-install_only.tar.gz
NEXUS_EMBEDDED_PYTHON_SHA256=REPLACE_WITH_64_HEX_CHARS
NEXUS_EMBEDDED_PYTHON_SIZE=REPLACE_WITH_ARCHIVE_SIZE_BYTES

# Optional — archive format. Defaults to `tar.gz`. Use `zip` for
# the Windows embeddable distribution.
# NEXUS_EMBEDDED_PYTHON_KIND=tar.gz

# Optional — top-level component inside the archive to strip during
# extraction. Defaults to `python`. Empty string means no strip.
# NEXUS_EMBEDDED_PYTHON_STRIP=python

# Optional — install-root-relative directory to extract into.
# Defaults to `python`; changing it also requires updating
# family_python::handler::python_exe_in in lockstep.
# NEXUS_EMBEDDED_PYTHON_EXTRACT=python

# File:// URLs also work for air-gapped / CI setups:
# NEXUS_EMBEDDED_PYTHON_URL=file:///opt/nexus/assets/cpython-3.11.tar.gz
